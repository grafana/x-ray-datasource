{
  "name": "grafana-x-ray-datasource",
  "version": "2.17.0",
  "description": "AWS Application Signals data source",
  "private": true,
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes --ignore-scripts --package @grafana/sign-plugin@3.2.2 sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:changes": "jest --coverage --changedSince=origin/main",
    "typecheck": "tsc --noEmit"
  },
  "author": "Grafana",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.5",
    "@grafana/plugin-ui": "0.16.0",
    "@grafana/runtime": "12.4.5",
    "@grafana/schema": "12.4.5",
    "@grafana/ui": "12.4.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "semver": "7.8.5",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@babel/core": "7.29.7",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@grafana/aws-sdk": "0.11.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.9.1",
    "@grafana/sign-plugin": "3.3.0",
    "@grafana/tsconfig": "2.2.0",
    "@openfeature/web-sdk": "1.9.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.2",
    "@types/prismjs": "1.26.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/semver": "7.7.1",
    "@types/slate": "0.47.16",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "9.8.0",
    "css-loader": "7.1.4",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "prismjs": "1.30.0",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.101.0",
    "sass-loader": "16.0.8",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "5.108.0",
    "webpack-cli": "7.0.3",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=24",
    "yarn": "4.17.0"
  }
}
